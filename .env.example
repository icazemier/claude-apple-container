# ─── claude-apple-container — environment variables ──────────────────────────
# Copy this file to .env and uncomment the lines you want to use.
# Changes take effect on the next container start (./stop.sh && ./up.sh).

# Host directory to mount inside the container at /home/claude/shared.
# SHARED_FOLDER=/path/to/your/project

# Comma-separated TCP ports to forward from host to container.
# Services are reachable at localhost:<port> on the host.
# FORWARDED_PORTS=3000,3001,5173

# Container name. Default: claude-dev.
# CONTAINER_NAME=claude-dev

# VM resources. Default: 8G RAM, 4 CPUs.
# The 1 GiB Apple default is too low for Claude Code + Chromium.
# VM_MEMORY=8G
# VM_CPUS=4

# Comma-separated paths to copy into /home/claude on every ./up.sh.
# Directories and files under ~ are placed at the same relative path.
# Only copies if the file doesn't already exist in the VM.
# Survives destroy --all.
# DOTFILES=~/.ssh,~/.gitconfig,~/.npmrc

# Comma-separated project folders to copy into /home/claude on every ./up.sh.
# Only copies if the folder doesn't already exist in the VM.
# node_modules are excluded (they go to tmpfs via nm-local).
# Survives destroy --all.
# COPY_FOLDERS=~/Development/MyProject,~/Development/AnotherProject

# Extra Alpine packages to install on every ./up.sh.
# Survives destroy + recreate. Space-separated.
# EXTRA_PACKAGES=htop redis postgresql-client

# ─── VM watchdog / swap tuning ───────────────────────────────────────────────
# These control the in-VM memory watchdog and swap setup.
# Tune if you change VM_MEMORY — defaults are sized for 8G.

# Swap size (sparse file, only uses actual pages on disk). Default: 2G.
# SWAP_SIZE=2G

# Available memory (MB) below which the watchdog SIGSTOPs heavy processes.
# WATCHDOG_MEM_CRIT_MB=400

# Available memory (MB) above which throttled processes are resumed.
# WATCHDOG_MEM_RESUME_MB=1200

# Watchdog poll interval in seconds. Default: 5.
# WATCHDOG_POLL=5
